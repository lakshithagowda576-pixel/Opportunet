{
  "name": "opportu-net-workspace",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --filter \"@workspace/api-server\" --filter \"@workspace/job-portal\" --parallel dev",
    "dev:all": "pnpm -r --parallel dev",
    "install:all": "pnpm install",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck": "tsc --build && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "seed": "pnpm -C scripts run seed --env-file=.env"
  },
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
